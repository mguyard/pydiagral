{
  "name": "pydiagral Dev",
  "context": "..",
  "dockerFile": "./Dockerfile.dev",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "PYPROJECT_VERSION=0.1.0-dev pip install -e .[dev] && mkdir -p ~/.gnupg && chmod 700 ~/.gnupg && echo -n '' > ~/.gnupg/common.conf && gpg --import /tmp/gpg-devcontainer.asc 2>&1 | grep -v secret && echo 'export GPG_TTY=$(tty)' >> ~/.zshrc",
  "runArgs": [
    "-e",
    "GIT_EDITOR=code --wait"
  ],
  "mounts": [
    "source=${localEnv:HOME}/.config/gpg-devcontainer.asc,target=/tmp/gpg-devcontainer.asc,type=bind,readonly"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "ms-python.vscode-pylance",
        "redhat.vscode-yaml",
        "esbenp.prettier-vscode",
        "GitHub.vscode-pull-request-github",
        "GitHub.copilot"
      ],
      // Please keep this file in sync with settings in .vscode/settings.default.json
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.pythonPath": "/usr/local/bin/python",
        "python.terminal.activateEnvInCurrentTerminal": true,
        "python.testing.pytestArgs": [
          "--no-cov"
        ],
        "pylint.importStrategy": "fromEnvironment",
        "python.linting.enabled": true,
        "python.linting.ruffEnabled": true,
        "python.linting.pylintEnabled": false,
        "python.linting.flake8Enabled": false,
        "editor.formatOnPaste": false,
        "editor.formatOnSave": true,
        "editor.formatOnType": true,
        "files.trimTrailingWhitespace": true,
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/usr/bin/zsh"
          }
        },
        "terminal.integrated.defaultProfile.linux": "zsh",
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  }
}